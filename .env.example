# =============================================
# LocalPulse — Environment Variables
# =============================================
# Copy this file to .env and fill in your keys
# Get free API keys at the URLs listed below
# =============================================

# Server
PORT=3000
NODE_ENV=development

# Supabase (free at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# OpenAI (platform.openai.com)
OPENAI_API_KEY=sk-your-openai-key

# Google Places API (console.cloud.google.com — free tier: 5k calls/month)
GOOGLE_PLACES_API_KEY=your-google-places-key

# Yelp Fusion API (free at yelp.com/developers)
YELP_API_KEY=your-yelp-fusion-key

# Twilio — SMS automations (twilio.com — free trial)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1your-twilio-number

# App-level API key (make this anything secret — used to protect your API)
APP_API_KEY=localpulse-secret-key-change-this

# Email (for weekly digests — use Gmail SMTP or Resend.com free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# n8n webhook base URL (where your n8n instance runs)
N8N_WEBHOOK_URL=http://localhost:5678
